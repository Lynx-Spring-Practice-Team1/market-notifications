APP_NAME=market-notifications
ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://market_notifications:market_notifications@localhost:5435/market_notifications_db

KAFKA_ENABLED=true
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_NOTIFICATION_TOPIC=notification.created

MARKET_WS_ENABLED=true
EXCHANGE_WS_URL=ws://localhost:8080/ws
EXCHANGE_WS_API_KEY=test-api-key
EXCHANGE_WS_API_SECRET=test-api-secret
EXCHANGE_WS_RECONNECT_SECONDS=5
